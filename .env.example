PORT=8005
ENVIRONMENT=development

# LIGHTHOUSE_API_KEY=your_lighthouse_api_key_here


AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

X402_RECIPIENT_ADDRESS=
# X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base-sepolia
X402_PRICE_PER_MB=0.01

# Optional (new)
MAX_FILE_SIZE_BYTES=4294967296  # 4GB

# Wasabi S3
WASABI_ACCESS_KEY_ID=test
WASABI_SECRET_ACCESS_KEY=test
WASABI_BUCKET_NAME=x402-uploads
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# Lighthouse Wallet (for later IPFS uploads)
LIGHTHOUSE_WALLET_PRIVATE_KEY=your_wallet_private_key


# Lighthouse API (required for IPFS upload)
LIGHTHOUSE_API_KEY=your_lighthouse_api_key

# Worker Intervals (optional, defaults shown)
S3_TO_IPFS_INTERVAL_MS=300000      # 5 minutes
DEAL_CHECK_INTERVAL_MS=900000      # 15 minutes

# Enable/Disable Workers (optional)
WORKERS_ENABLED=false               # Set to false to disable

# ----------

# RPC URLs (optional - defaults provided)
RPC_BASE_MAINNET=https://mainnet.base.org
RPC_BASE_SEPOLIA=https://sepolia.base.org

# Verification settings
PAYMENT_VERIFICATION_ENABLED=true    # Enable/disable on-chain check
PAYMENT_MIN_CONFIRMATIONS=1          # Min confirmations required