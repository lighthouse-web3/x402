# Server
PORT=4021
NODE_ENV=development
SERVICE_NAME=x402-lighthouse

# Logging (levels: error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# Victoria Logs (optional — leave empty to disable remote logging)
VICTORIA_LOGS_URL=
VICTORIA_LOGS_TOKEN=

# Your wallet address that receives USDC payments
RECIPIENT_ADDRESS=0xYourWalletAddress

# Lighthouse API key (get one at https://files.lighthouse.storage/)
LIGHTHOUSE_API_KEY=your_lighthouse_api_key

# Network — Base Sepolia testnet (use eip155:8453 for mainnet)
NETWORK=eip155:84532

# x402 facilitator
# Testnet:  https://www.x402.org/facilitator
# Mainnet:  https://api.cdp.coinbase.com/platform/v2/x402 (requires CDP keys below)
FACILITATOR_URL=https://www.x402.org/facilitator

# CDP API keys (required for mainnet facilitator — get from https://portal.cdp.coinbase.com/)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Walrus storage plan pricing ($11/month base for 250 GB, billed yearly = $132/year)
STORAGE_PRICE_USD=11
STORAGE_QUOTA_GB=250
# Billing period: number of months charged per payment (12 = yearly)
BILLING_PERIOD_MONTHS=12
BILLING_PERIOD_LABEL=year
# Optional override — per-MiB price for the whole billing period
# defaults to (STORAGE_PRICE_USD * BILLING_PERIOD_MONTHS) / (STORAGE_QUOTA_GB * 1024)
# PRICE_PER_MB=0.000515625
FACILITATOR_FEE=0.001
# Days of storage granted per upload or renew payment (365 = yearly)
STORAGE_PERIOD_DAYS=365

# Max file size in bytes (default 100 MB)
MAX_FILE_SIZE_BYTES=104857600

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
FILE_RECORD_TABLE=files-x402
