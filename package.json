{
  "name": "x402-api",
  "version": "1.0.0",
  "description": "x402 payment API for Lighthouse file uploads",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npx tsc",
    "start": "node ./dist/src/index.js",
    "start:prod": "npm run build && node ./dist/src/index.js",
    "lint": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.+(js|ts|json)\""
  },
  "keywords": [
    "x402",
    "lighthouse",
    "ipfs",
    "payment"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.549.0",
    "@aws-sdk/lib-dynamodb": "^3.549.0",
    "@lighthouse-web3/sdk": "^0.4.3",
    "@solana/web3.js": "^1.91.4",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.11.1",
    "express": "^4.19.2",
    "express-winston": "^4.2.0",
    "morgan": "^1.10.0",
    "secp256k1": "^5.0.0",
    "winston": "^3.13.0",
    "x402": "^0.1.0",
    "x402-express": "^0.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.5",
    "@types/secp256k1": "^4.0.6",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.4.4"
  }
}
